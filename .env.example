APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Opcional: túnel HTTPS com Docker (imagem ngrok oficial), sem instalar o CLI no host.
# 1) Token em https://dashboard.ngrok.com/get-started/your-authtoken
# 2) NGROK_AUTHTOKEN=...
# 3) Subir Sail com perfil: COMPOSE_PROFILES=ngrok ./vendor/bin/sail up -d
# 4) URL pública em http://localhost:4040 (API do ngrok) e definir APP_URL=https://<subdomínio>.ngrok-free.app
# NGROK_AUTHTOKEN=
# FORWARD_NGROK_WEB_PORT=4040

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Destinatário do nó email_approval na PoC (seeder WorkflowEmailApprovalDemoSeeder).
# Se vazio, usa MAIL_FROM_ADDRESS.
WORKFLOW_EMAIL_APPROVAL_TO=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel AI (workflow: nó AI, AI Builder no editor) — ver config/ai.php
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# WORKFLOW_AI_PROVIDER=openai
# WORKFLOW_AI_MODEL=gpt-4o
# WORKFLOW_AI_MAX_TOKENS=4096
# WORKFLOW_AI_BUILDER_ENABLED=true
# WORKFLOW_AI_BUILDER_PROVIDER=openai
# WORKFLOW_AI_BUILDER_MODEL=gpt-4o
# WORKFLOW_MCP_ENABLED=false

# OpenAI (opcional) — extração de campos e copiloto na página workflow-forms
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=60

# Sybase SAU — credenciais de teste para prss_login_r01 (config sau.prss_login: id, tipo, senha)
# SAU_PRSS_LOGIN_CREDENTIAL_ID=
# SAU_PRSS_LOGIN_CREDENTIAL_TYPE=COD
# SAU_PRSS_LOGIN_PASSWORD=
